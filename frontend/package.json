{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --grep=\"Visual Regression\"",
    "test:performance": "playwright test --grep=\"Performance Tests\"",
    "test:cross-browser": "playwright test --grep=\"Cross-Browser\"",
    "test:responsive": "vitest run responsive",
    "test:scrolling": "npm run test:run -- --grep=\"scrolling\"",
    "test:container-sizes": "playwright test src/test/integration/ContainerSizeIntegration.test.ts",
    "test:container-layout": "vitest run src/components/__tests__/LayoutCalculations.test.tsx",
    "test:container-responsive": "vitest run src/test/responsive/ContainerResponsive.test.tsx",
    "test:container-visual": "playwright test src/test/visual/ContainerSizing.visual.spec.ts",
    "test:container-cross-browser": "playwright test src/test/e2e/ContainerCrossBrowser.spec.ts",
    "test:container-all": "npm run test:container-layout && npm run test:container-responsive && npm run test:container-sizes && npm run test:container-visual && npm run test:container-cross-browser",
    "test:all": "npm run test:run && npm run test:e2e && npm run test:container-all"
  },
  "dependencies": {
    "@types/node": "^24.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.540.0",
    "playwright": "^1.54.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-syntax-highlighter": "^15.6.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "@playwright/test": "^1.54.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/ui": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "vitest": "^2.1.8",
    "jsdom": "^26.0.0",
    "happy-dom": "^15.11.6"
  }
}
